{
  "name": "cruft",
  "version": "0.1.0",
  "description": "Find and clean gigabytes of developer cruft on your Mac. Terminal-native. Safe by default.",
  "type": "module",
  "bin": {
    "cruft": "./dist/cruft"
  },
  "scripts": {
    "dev": "bun src/index.tsx",
    "build": "bun build --compile --minify --target=bun-darwin-arm64 --define 'process.env.NODE_ENV=\"production\"' ./src/index.tsx --outfile ./dist/cruft",
    "build:x64": "bun build --compile --minify --target=bun-darwin-x64 ./src/index.tsx --outfile ./dist/cruft-x64",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "typecheck": "bun run build 2>/dev/null || true"
  },
  "files": ["dist/"],
  "keywords": ["cruft", "cleanup", "macos", "developer-tools", "tui"],
  "license": "MIT",
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.2.0",
    "dayjs": "^1.11.0",
    "execa": "^9.0.0",
    "fast-folder-size": "^2.0.0",
    "fast-glob": "^3.3.0",
    "fuse.js": "^7.0.0",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "p-limit": "^7.0.0",
    "p-map": "^7.0.0",
    "react": "18",
    "react-devtools-core": "^7.0.1",
    "react-dom": "18",
    "smol-toml": "^1.3.0",
    "trash": "^9.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/react": "^18.2.0",
    "@types/node": "^20.0.0",
    "ink-testing-library": "^4.0.0",
    "memfs": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
